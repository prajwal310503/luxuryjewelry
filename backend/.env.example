PORT=8000
BACKEND_URL=http://localhost:8000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/luxury_jewelry?retryWrites=true&w=majority&appName=Cluster0

# ── JWT ────────────────────────────────────────────────────────────────────────
# Use a long random string (32+ chars)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# For Gmail: enable 2FA then generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Luxury Jewelry

# ── Razorpay ───────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Frontend URL ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Admin seed credentials (used by: node src/utils/seeder.js) ─────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=StrongAdminPassword@123

# ── Vendor seed credentials (used by: node src/utils/seedProducts.js) ──────────
VENDOR=vendor@yourdomain.com
PASSWORD=StrongVendorPassword@123
