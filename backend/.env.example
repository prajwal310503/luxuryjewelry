PORT=5000
NODE_ENV=production

# MongoDB Atlas — replace with your connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/luxury_jewelry?retryWrites=true&w=majority

# JWT — use a long random string (32+ chars)
JWT_SECRET=change_this_to_a_random_secret_string
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Luxury Jewelry

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_key_secret

# Frontend URL (your Vercel/Netlify URL after deploy)
FRONTEND_URL=https://your-app.vercel.app

# Admin seed credentials
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=StrongPassword@123
